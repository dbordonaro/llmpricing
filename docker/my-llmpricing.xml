<?xml version="1.0"?>
<Container version="2">
  <Name>LLMPricing</Name>
  <Repository>ghcr.io/dbordonaro/llmpricing:latest</Repository>
  <Registry>https://github.com/dbordonaro/llmpricing</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>bash</Shell>
  <Privileged>false</Privileged>
  <Support/>
  <Project>https://github.com/dbordonaro/llmpricing</Project>
  <Category>Utilities:Tools</Category>
  <WebUI>http://[IP]:[PORT:8080]</WebUI>
  <TemplateURL/>
  <Icon>https://raw.githubusercontent.com/sanand0/llmpricing/master/favicon.ico</Icon>
  <ExtraParams>--restart=unless-stopped</ExtraParams>
  <PostArgs/>
  <CPUset/>
  <DateInstalled>1722806126</DateInstalled>
  <DonateText/>
  <DonateLink/>
  <Requises/>
  <Config Name="Web Port" Target="80" Default="8080" Mode="tcp" Description="Host port for the web interface. Default: 8080" Type="Port" Display="always" Required="true" Mask="false">8080</Config>
  <Config Name="Timezone" Target="TZ" Default="America/Los_Angeles" Mode="" Description="Container timezone" Type="Variable" Display="always" Required="false" Mask="false">America/Los_Angeles</Config>
  <Config Name="GitHub Token" Target="GITHUB_TOKEN" Default="" Mode="" Description="Classic PAT with repo scope. Set this + FORK_OWNER to enable push access for code changes." Type="Variable" Display="always" Required="false" Mask="true"/>
  <Config Name="Fork Owner" Target="FORK_OWNER" Default="" Mode="" Description="Your GitHub username (the fork owner). Only needed if you want Dobby to push code changes." Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Git User Name" Target="GIT_USER_NAME" Default="" Mode="" Description="Name for git commits (e.g. Dobby Bot)" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Git User Email" Target="GIT_USER_EMAIL" Default="" Mode="" Description="Email for git commits" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Source Code Volume" Target="/app/repo" Default="" Mode="rw" Description="Persistent volume so code changes survive container rebuilds. Map to /mnt/user/appdata/llmpricing/repo" Type="Path" Display="always" Required="false" Mask="false"/>
</Container>
